generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Website {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  template  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  couple    Couple?
  events    Event[]
  galleries Gallery[]
  stories   Story[]
  gifts     Gift[]

  @@index([slug])
}

model Couple {
  id        Int @id @default(autoincrement())
  websiteId Int @unique

  groomName   String
  groomParent String
  groomPhoto  String?

  brideName   String
  brideParent String
  bridePhoto  String?

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Event {
  id        Int @id @default(autoincrement())
  websiteId Int

  name     String
  date     String
  time     String
  location String
  address  String
  mapsUrl  String?

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Gallery {
  id        Int @id @default(autoincrement())
  websiteId Int
  imageUrl  String

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Story {
  id        Int @id @default(autoincrement())
  websiteId Int

  title       String
  date        String
  description String

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Gift {
  id        Int @id @default(autoincrement())
  websiteId Int

  bank   String
  name   String
  number String

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}